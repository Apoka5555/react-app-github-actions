{
  "name": "react-app",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "msw": "^2.13.2",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test:e2e": "npm run build && playwright test",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/",
    "tsc:src": "tsc --project tsconfig.json --noEmit",
    "prettier:fix": "prettier --write .",
    "prettier:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.4",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.4.12",
    "serve": "^14.2.6",
    "tailwindcss": "^3.0.24",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.8"
  },
  "msw": {
    "workerDirectory": "public"
  }
